{
  "type": "module",
  "dependencies": {
    "hono": "^4.12.30",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/workers-types": "^5.20260718.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run types:check && npm run typecheck && vite build",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy",
    "types": "wrangler types --env-interface CloudflareBindings --strict-vars false",
    "types:check": "wrangler types --env-interface CloudflareBindings --strict-vars false --check",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p tsconfig.worker.json",
    "scrape": "tsx scripts/scrape-tabelog.ts"
  }
}
